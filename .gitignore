# ───────────────────────── Dependencies ─────────────────────────
node_modules/
.bun/

# ──────────────────────── Build output ──────────────────────────
dist/
apps/web/dist/
apps/web/.angular/
.angular/
*.tsbuildinfo

# ─────────── Generated content (rebuilt by tools/build-blog.ts) ──────────
# Source of truth is apps/web/content/blog/*.md — these are build artifacts.
# (Uploaded post images under apps/web/public/blog/<slug>/ stay tracked.)
apps/web/src/app/core/data/blog.generated.ts
apps/web/public/rss.xml
apps/web/public/sitemap.xml
apps/web/public/blog/*.md
apps/web/public/blog/**/og.png

# ─────────────────────── Env & secrets ──────────────────────────
.env
.env.*
!.env.example
deploy/.env

# Cloudflare tunnel credentials — never commit
deploy/cloudflared/*.json
deploy/cloudflared/cert.pem
deploy/cloudflared/config.yml

# ──────────────────── Testing & coverage ────────────────────────
coverage/
/out-tsc
__screenshots__/

# ───────────────────────── Logs ─────────────────────────────────
*.log
npm-debug.log*
yarn-error.log*
bun-debug.log*

# ──────────────────────── Editor & OS ───────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
.history/
.DS_Store
Thumbs.db
