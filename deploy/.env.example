# Copy to deploy/.env and fill in. deploy/.env is git-ignored.

# Cloudflare Tunnel token (token-based / remotely-managed tunnel).
# Get it from: Zero Trust dashboard → Networks → Tunnels → your tunnel →
# Configure → Docker. Paste only the token value below.
TUNNEL_TOKEN=

# Hostnames the SSR server will accept (comma-separated). Must match the
# public hostname(s) routed by the tunnel.
NG_ALLOWED_HOSTS=outhanchazima.dev,www.outhanchazima.dev
