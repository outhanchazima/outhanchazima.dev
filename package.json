{
  "name": "outhanchazima-dev",
  "version": "1.0.0",
  "private": true,
  "description": "Outhan Chazima — senior software engineer portfolio. Angular 22 SSR, TailwindCSS, served on Bun.",
  "license": "MIT",
  "type": "module",
  "workspaces": ["apps/*"],
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "cd apps/web && bun run start",
    "build": "cd apps/web && bun run build",
    "start": "bun apps/web/dist/web/server/server.mjs",
    "test": "cd apps/web && bun run test",
    "assets": "cd apps/web && bun run tools/generate-assets.ts",
    "docker:build": "docker compose -f deploy/docker-compose.yml build",
    "docker:up": "docker compose -f deploy/docker-compose.yml up -d",
    "docker:down": "docker compose -f deploy/docker-compose.yml down",
    "docker:logs": "docker compose -f deploy/docker-compose.yml logs -f",
    "deploy": "bash deploy/scripts/deploy.sh"
  }
}
